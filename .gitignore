# --- Entorno de Servidor Local (XAMPP/PHP) ---
# Ignorar archivos de configuración de base de datos local que contienen contraseñas
src/config/db_local.php
config.local.php
.env

# Archivos temporales y logs de PHP/Apache
*.log
error_log
access_log
php_errors.log

# --- Frontend & Tailwind ---
# Si en el futuro se usa NPM para Tailwind
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos de build o mapas de CSS si se generan
public/css/*.map

# --- Hardware (Arduino IDE / ESP32) ---
# Archivos temporales de compilación
hardware/**/build/
hardware/**/bin/
hardware/**/out/

# Archivos de configuración local de librerías o IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Archivos de Sistema Operativo ---
# Windows
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# --- Base de Datos ---
# No es recomendable subir dumps de SQL muy pesados al repo
*.sql
*.sql.gz